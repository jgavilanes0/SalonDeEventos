@page "/sedes"
@rendermode InteractiveServer
@inject IRepositorioSedes Repositorio
@inject NavigationManager Navigation
<PageTitle>Sedes</PageTitle>

<h3>Listado de sedes</h3>
<button class="btn btn-primary mb-3" @onclick='@(() => Navigation.NavigateTo("/sedes/nueva"))'>Nueva sede</button>

@if (!string.IsNullOrEmpty(_mensajeError))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error:</strong> @_mensajeError
        <button type="button" class="btn-close" @onclick="CerrarAlerta"></button>
    </div>
}

@if (_sedes == null)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Cargando...</span>
    </div>
}
else if (_sedes.Count == 0)
{
    <div class="alert alert-info">
        <h2>No se encuentran registradas sedes</h2>
    </div>
}
else
{
    <QuickGrid Items="_sedes.AsQueryable()" Class="table table-striped" Pagination="_paginationState">
        <PropertyColumn Property="@(s => s.Nombre)" Sortable="true" />
        <PropertyColumn Property="@(s => s.Ubicacion)" />
        <PropertyColumn Property="@(s => s.Capacidad)" />
        <TemplateColumn Title="Acciones">
            <button class="btn btn-outline-secondary" @onclick="@(() => Eliminar(context))">Eliminar</button>
            <button class="btn btn-outline-primary" @onclick="@(() => Editar(context))">Editar</button>
        </TemplateColumn>
    </QuickGrid>
    <Paginator State="_paginationState" />
}

@code {
    private List<Sede>? _sedes;
    private PaginationState _paginationState = new PaginationState { ItemsPerPage = 5 };
    private string? _mensajeError; // Variable para guardar el mensaje de error

    protected override async Task OnInitializedAsync()
    {
        _sedes = await Repositorio.ObtenerSedes();
    }

    private void Editar(Sede sede)
    {
        Navigation.NavigateTo($"/sedes/editar/{sede.Id}");
    }

    private async Task Eliminar(Sede sede)
    {
        try
        {
            _mensajeError = null; // Limpiamos errores anteriores
            await Repositorio.EliminarSede(sede.Id);
            _sedes = await Repositorio.ObtenerSedes(); // Si se borró bien, actualizamos la tabla
        }
        catch (Exception ex)
        {
            // Atrapamos la excepción del repositorio y la mostramos en pantalla
            _mensajeError = ex.Message;
        }
    }

    private void CerrarAlerta()
    {
        _mensajeError = null;
    }
}